rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the owner can read/write their profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Habits: user-scoped subcollection
    match /habits/{userId}/items/{habitId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Habit logs: daily completion data per user
    match /habitLogs/{userId}/daily/{date} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reminders: casual and dated
    match /reminders/{userId}/casual/{reminderId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /reminders/{userId}/dated/{reminderId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Daily stats (streak, etc.)
    match /dailyStats/{userId}/days/{date} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
