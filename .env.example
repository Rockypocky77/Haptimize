# Backend
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
FLASK_DEBUG=true

# Firebase (server)
FIREBASE_ADMIN_CREDENTIALS=./secrets/firebase-admin.json

# Email verification (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Haptimize <noreply@haptimize.app>
ALLOW_MOCK_EMAIL=true

# AI — NEVER commit real keys; use .env only
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# Optional future auth setting
ENABLE_GOOGLE_EXCHANGE=false
